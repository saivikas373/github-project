  switchport access vlan 3089
  mtu 9178
  no shutdown
  exit

  interface Ethernet1/x
 description [TYPE=DC_CUST][BW=1G][NAME=VO][ZLOC=HOST NAME coloumn][ZPORT=ILOM][IP=y]


